# Các thư mục phụ thuộc (Dependencies)
# Không đẩy node_modules lên vì nó rất nặng và có thể cài lại bằng lệnh npm install
node_modules/
/jspm_packages/

# Các thư mục build (Production)
# Đây là các tệp được tạo ra sau khi chạy lệnh build, không cần thiết để lưu trữ phiên bản
bin/
build/
dist/
out/
.next/

# Các tệp cấu hình cá nhân hoặc môi trường (Environment variables)
# QUAN TRỌNG: Không bao giờ đẩy các tệp .env chứa API Key hoặc mật khẩu lên GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Các tệp log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Các tệp hệ điều hành
.DS_Store
Thumbs.db
desktop.ini

# Cấu hình IDE (VS Code, WebStorm, v.v.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

